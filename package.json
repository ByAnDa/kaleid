{
  "name": "kaleid",
  "version": "0.0.4",
  "description": "A terminal coding harness agent for OpenAI Codex OAuth.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ByAnDa/kaleid.git"
  },
  "keywords": [
    "agent",
    "cli",
    "terminal",
    "harness",
    "codex"
  ],
  "bin": {
    "kaleid": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build && npm run typecheck",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "ink": "^5",
    "ink-spinner": "^5",
    "ink-text-input": "^6",
    "react": "^18",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^18",
    "esbuild": "^0.24",
    "tsx": "^4",
    "typescript": "^5.6"
  }
}
